// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  MODERATOR
  USER
  // "Гость" — НЕ значение этого enum, а отсутствие валидной сессии/JWT.
  // Не добавлять GUEST сюда — см. streamer.API#15 / steramer.io#1.
}

model User {
  id           String   @id @default(cuid())
  login        String   @unique
  passwordHash String?
  provider     String?
  googleId     String?  @unique
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      Profile?
  settings     Settings?
  gameAccounts GameAccount[]
  socialLinks  SocialLink[]
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  email     String?
  name      String?
  avatarUrl String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GameAccount {
  id         String   @id @default(cuid())
  userId     String
  nickname   String
  externalId String // id аккаунта в игре, не путать с id этой строки
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SocialLinkType {
  EMAIL
  TELEGRAM
  TIKTOK
  PHONE
  VIBER
}

model SocialLink {
  id        String         @id @default(cuid())
  userId    String
  type      SocialLinkType
  value     String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Theme {
  LIGHT
  DARK
  SYSTEM // "как на устройстве" — тема подстраивается под системную настройку клиента
}

model Settings {
  id                   String  @id @default(cuid())
  userId               String  @unique
  theme                Theme   @default(SYSTEM)
  receiveNotifications Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Schedule {
  id         String  @id @default(cuid())
  weekday    Weekday @unique
  isOnline   Boolean @default(false)
  eventTitle String?
  time       String?
}
