# Copy to .env and fill in your local values. .env is not committed (see .gitignore).
# Validated at startup (src/config/env.validation.ts) — the app refuses to start if a required value is missing/invalid.

DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"
NODE_ENV="development"
PORT="3000"
CORS_ORIGIN="http://localhost:4200"
JWT_SECRET="replace-with-a-random-32+-character-secret"
JWT_EXPIRES_IN="7d"
