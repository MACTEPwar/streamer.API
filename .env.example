# Copy to .env and fill in your local values. .env is not committed (see .gitignore).
# Validated at startup (src/config/env.validation.ts) — the app refuses to start if a required value is missing/invalid.

DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"
NODE_ENV="development"
PORT="3000"
CORS_ORIGIN="http://localhost:4200"
JWT_SECRET="replace-with-a-random-32+-character-secret"
JWT_EXPIRES_IN="7d"
GOOGLE_CLIENT_ID="replace-with-real-google-oauth-client-id"

# Placeholder — the real donator provider isn't chosen yet (streamer.API#40).
# Optional: MockDonatorsProvider doesn't read it. Wired up now so a real
# provider can be plugged in later without touching env.validation.ts.
DONATOR_SERVICE_TOKEN="replace-with-real-donator-service-token"

# Only needed for `npx prisma db seed` (creates the default admin user),
# NOT validated/required for a normal app start — see prisma/seed.ts.
SEED_ADMIN_LOGIN="admin"
SEED_ADMIN_PASSWORD="replace-with-a-strong-password"
